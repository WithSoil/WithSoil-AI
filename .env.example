# 이 파일을 복사해서 .env로 만들고 실제 값을 채워주세요.
#   Windows : copy .env.example .env
#   Mac/Linux: cp .env.example .env
# 실제 키/토큰 값은 절대 git에 커밋하지 마세요. (.env는 .gitignore에 의해 추적되지 않습니다)

# Google Gemini API 키 (RAG/챗봇 기능에 사용)
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Hugging Face에 업로드된 작물 병해 진단 모델 정보
HF_MODEL_ID=your_huggingface_repo_id_here
HF_MODEL_FILE=best_efficientnet_b3_with_normal_20crops.pth

# Hugging Face repo가 private인 경우에만 필요 (public repo면 비워둬도 됩니다)
HF_TOKEN=
